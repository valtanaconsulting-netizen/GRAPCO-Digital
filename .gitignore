# .gitignore de la RAÍZ del repo (GRAPCO-Digital)
# El código vive en las carpetas "1. GRAPCO ..." a "4. GRAPCO ..." (cada una con su propio .gitignore).

# Config local de herramientas, por máquina — NO versionar
.claude/
settings.local.json

# Documentos de referencia sueltos en la raíz (su data ya vive en el código .js).
# Solo nivel raíz (no afecta plantillas dentro de la app, p.ej. public/plantillas/*.xlsx).
/*.xlsx
/*.pdf
/*.docx
/*.mp4

# Material de obra real y entornos locales — NO versionar (pesan ~1 GB, no son código)
/05. Gestión Costos/
.venv/

# Backups de reglas / artefactos regenerables
*.original.bak

# Credenciales — NUNCA versionar, en ninguna carpeta (el repo es público)
serviceAccount*.json

# Datasets de ML: datos reales de obra — NO versionar en un repo público
/ml/datasets/
/ml/modelos/

# Bytecode de Python: regenerable
__pycache__/
*.pyc

# Tesis: pesada (PDF/imágenes/versiones) y con su propio control en VERSIONES_PREVIAS/ — NO versionar
/INFORME DE TESIS/

# Archivo histórico de la limpieza de producción (2026-07-06): docs, scratch y one-shots retirados — NO versionar
/_ARCHIVO - PRODUCCION - VALORIZACION/

# Proyectos paralelos no versionados en este repo
/PAQUETE_REIMPORTACION_CREDITEX_S1-8/
/PROYECTO_CASA_DEMO_4SEMANAS/
