<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Edge-to-edge: el contenido (navy) se dibuja DETRÁS de las barras del
             sistema. La barra de estado (hora/batería) y la de navegación (los 3
             botones) quedan transparentes y VISIBLES encima del navy. -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Dibuja dentro del notch/punch-hole (sin franja negra arriba). API 28+ -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>


    <!-- Pantalla de arranque: fondo NAVY sólido (no el splash con logo + texto
         "PLATAFORMA GRAPCO S.A.C."). Así el arranque va DIRECTO al loader animado de
         la web (el #gp-boot navy del index.html aparece al instante) sin mostrar antes
         la pantalla de marca, que se sentía como un paso extra desagradable.
         - windowSplashScreenBackground: fondo del splash del sistema en Android 12+.
         - android:background: mismo navy para el windowBackground en versiones previas.
         - postSplashScreenTheme: al terminar el splash se pasa al tema real (edge-to-edge). -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splashNavy</item>
        <item name="android:background">@color/splashNavy</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>