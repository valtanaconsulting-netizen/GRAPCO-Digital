// ════════════════════════════════════════════════════════════════════════════
// storage.rules — Reglas de seguridad Firebase Storage GRAPCO v2 (Bloque 12)
//
// MODELO DE PERMISOS:
//   - Solo usuarios autenticados pueden subir/leer
//   - Validación de tipo MIME (solo imágenes para fotos, solo modelos BIM para CAD)
//   - Validación de tamaño máximo (anti-abuso)
//   - Capataz solo sube a SU carpeta personal
//
// COMO DESPLEGAR:
//   firebase deploy --only storage
// ════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── HELPERS ──
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function getUserDoc() {
      return firestore.get(/databases/(default)/documents/Usuarios/$(uid()));
    }
    function getRol() { return getUserDoc().data.rol; }
    function isCapataz()   { return isAuth() && getRol() == 'capataz'; }
    function isIngeniero() { return isAuth() && getRol() == 'ingeniero'; }
    function isAdmin()     { return isAuth() && getRol() == 'admin'; }

    function isImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic)');
    }
    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // ════════════════════════════════════════════════════════════════
    // /fotos_capataz/{uidUsuario}/{registroId}/{nombreArchivo}
    // Fotos que el capataz sube de su trabajo en obra.
    //   - Solo el dueño puede subir a su carpeta
    //   - Solo imágenes
    //   - Máx 5 MB por foto (después del compresor de FotoUploader)
    //   - Cualquier ingeniero/admin puede leer
    // ════════════════════════════════════════════════════════════════
    match /fotos_capataz/{uidUsuario}/{registroId}/{archivo} {
      allow read: if isAuth();
      allow write: if isAuth()
                      && uid() == uidUsuario
                      && isImage()
                      && maxSize(5);
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════
    // /modelos_bim/{archivo}
    // Modelos BIM (.rvt, .ifc, .dwg). Solo ingenieros suben.
    // NOTA: el upload a APS pasa por Cloud Functions con signed URLs,
    //       NO por Firebase Storage directamente. Este path es para
    //       backups locales o thumbnails.
    // ════════════════════════════════════════════════════════════════
    match /modelos_bim/{archivo} {
      allow read: if isAuth();
      allow write: if (isIngeniero() || isAdmin())
                      && maxSize(500)  // 500 MB máx
                      && request.resource.contentType.matches(
                        'application/(octet-stream|x-revit|x-ifc|x-dwg)|model/.*'
                      );
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════
    // /reportes_pdf/{uidUsuario}/{nombreArchivo}
    // PDFs generados por el sistema (export de auditorías, planes, etc.)
    // ════════════════════════════════════════════════════════════════
    match /reportes_pdf/{uidUsuario}/{archivo} {
      allow read: if isAuth();
      allow write: if isAuth()
                      && uid() == uidUsuario
                      && request.resource.contentType == 'application/pdf'
                      && maxSize(20);  // 20 MB máx
      allow delete: if isAuth() && uid() == uidUsuario;
    }

    // ════════════════════════════════════════════════════════════════
    // /avatars/{uidUsuario}/{archivo}
    // Foto de perfil del usuario.
    // ════════════════════════════════════════════════════════════════
    match /avatars/{uidUsuario}/{archivo} {
      allow read: if isAuth();
      allow write: if isAuth()
                      && uid() == uidUsuario
                      && isImage()
                      && maxSize(2);
      allow delete: if isAuth() && uid() == uidUsuario;
    }

    // ════════════════════════════════════════════════════════════════
    // DENEGAR TODO LO DEMÁS
    // ════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
