# SIGMA — credenciales de TU proyecto Firebase (independiente de GRAPCO).
# Copia este archivo a ".env" y reemplaza con los valores de tu app web Firebase.
VITE_SIGMA_FIREBASE_API_KEY=
VITE_SIGMA_FIREBASE_AUTH_DOMAIN=tu-proyecto-sigma.firebaseapp.com
VITE_SIGMA_FIREBASE_PROJECT_ID=tu-proyecto-sigma
VITE_SIGMA_FIREBASE_STORAGE_BUCKET=tu-proyecto-sigma.appspot.com
VITE_SIGMA_FIREBASE_MESSAGING_SENDER_ID=
VITE_SIGMA_FIREBASE_APP_ID=
